# ── Telegram (required to enable the Telegram channel) ──────────────────────
# Create a bot via @BotFather on Telegram, copy the token here.
ANIMUS_TELEGRAM_TOKEN=

# ── LLM Authentication (at least one required) ───────────────────────────────
# Option 1: Run `podman compose up` from within a Claude Code terminal.
#   CLAUDE_CODE_OAUTH_TOKEN is automatically injected by the Claude Code CLI.
# Option 2: Set ANTHROPIC_API_KEY (standard API key from console.anthropic.com).
# Option 3: Set ANTHROPIC_OAUTH_TOKEN (manual OAuth token).
#
# Note: Claude Max OAuth (CLAUDE_CODE_OAUTH_TOKEN) supports Haiku models only.
# For Sonnet/Opus, use ANTHROPIC_API_KEY and set ANIMUS_MODEL below.
ANTHROPIC_API_KEY=

# ── LLM Model ────────────────────────────────────────────────────────────────
# Default: claude-haiku-4-5-20251001
# For Sonnet: claude-sonnet-4-20250514
# ANIMUS_MODEL=claude-haiku-4-5-20251001

# ── Embeddings ────────────────────────────────────────────────────────────────
# Default provider: ollama
# On macOS + Podman, set ANIMUS_OLLAMA_URL to your Mac's LAN IP:
ANIMUS_OLLAMA_URL=http://localhost:11434
# ANIMUS_EMBED_MODEL=mxbai-embed-large

# For OpenAI embeddings instead:
# ANIMUS_EMBED_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# ── Security ─────────────────────────────────────────────────────────────────
# Your Telegram user ID (get it from @userinfobot).
# Trusted IDs bypass heavy injection scanning — set this to your own ID.
ANIMUS_TRUSTED_TELEGRAM_IDS=

# ── Autonomy ─────────────────────────────────────────────────────────────────
# reactive: respond only when messaged (default, safest)
# goal_directed: pursue goals proactively + respond to messages
# full: fully autonomous
ANIMUS_AUTONOMY_MODE=reactive

# ── Federation (disabled by default) ─────────────────────────────────────────
# ANIMUS_FEDERATION=0
